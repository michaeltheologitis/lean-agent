# Copy this file to `.env` and fill in your Token Factory key.

NEBIUS_API_KEY=''

# Default Token Factory model for agent/tool smoke tests.
NEBIUS_MODEL_ID='deepseek-ai/DeepSeek-V3.2-fast'
NEBIUS_API_BASE='https://api.tokenfactory.nebius.com/v1/'

